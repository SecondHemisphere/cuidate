  <!-- Test Rápido -->
  <section class="test-interactivo">
    <h2>
      <i class="fas fa-question-circle"></i> ¿Qué tan preparado estás? - Test
      Rápido
    </h2>
    <p>
      Pon a prueba tus conocimientos básicos de primeros auxilios con este breve
      test.
    </p>
    <form id="testPrimerosAuxilios">
      <!-- Pregunta 1 -->
      <div class="pregunta">
        <label for="pregunta1"
          >¿Cuál es la primera acción ante una persona inconsciente?</label
        >
        <select id="pregunta1" name="pregunta1">
          <option value="">Selecciona una opción</option>
          <option value="llamar">Llamar a emergencias</option>
          <option value="revisar">Revisar si respira</option>
          <option value="daragua">Darle agua</option>
        </select>
      </div>
      <!-- Pregunta 2 -->
      <div class="pregunta">
        <label for="pregunta2">¿Cómo se detiene una hemorragia leve?</label>
        <select id="pregunta2" name="pregunta2">
          <option value="">Selecciona una opción</option>
          <option value="presion">Aplicando presión directa</option>
          <option value="torniquete">Aplicando un torniquete</option>
          <option value="agua">Lavando con agua fría</option>
        </select>
      </div>
      <!-- Pregunta 3 -->
      <div class="pregunta">
        <label for="pregunta3"
          >¿Cuánto tiempo se recomienda lavar las manos para una buena
          higiene?</label
        >
        <select id="pregunta3" name="pregunta3" required>
          <option value="">Selecciona una opción</option>
          <option value="10">10 segundos</option>
          <option value="20">Al menos 20 segundos</option>
          <option value="30">30 segundos</option>
        </select>
      </div>
      <!-- Pregunta 4 -->
      <div class="pregunta">
        <label for="pregunta4"
          >¿Cuál es el signo principal de un atragantamiento grave en un
          adulto?</label
        >
        <select id="pregunta4" name="pregunta4" required>
          <option value="">Selecciona una opción</option>
          <option value="tosvigorosa">Tos vigorosa</option>
          <option value="manuellcuello">
            Llevarse las manos al cuello (signo universal de asfixia)
          </option>
          <option value="llorar">Llorar o quejarse</option>
        </select>
      </div>
      <!-- Pregunta 5 -->
      <div class="pregunta">
        <label for="pregunta5"
          >¿Qué solución se utiliza comúnmente para lavar una herida
          leve?</label
        >
        <select id="pregunta5" name="pregunta5" required>
          <option value="">Selecciona una opción</option>
          <option value="alcohol">Alcohol</option>
          <option value="aguaoxigenada">Agua oxigenada</option>
          <option value="aguayjabon">Agua y jabón suave</option>
        </select>
      </div>
      <button type="submit">Ver resultados</button>
      <div id="resultadoTest" class="oculto"></div>
    </form>
  </section>
</main>
