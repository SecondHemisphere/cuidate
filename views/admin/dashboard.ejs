<div class="dashboard-contenedor" id="dashboard">
  <h1 class="titulo-dashboard">Dashboard</h1>

  <section class="seccion-dashboard">
    <h2 class="titulo-seccion">Usuarios</h2>
    <table id="tablaUsuarios" class="tabla-usuarios">
      <!-- Se llena dinámicamente con JS -->
    </table>
  </section>

  <section class="seccion-dashboard">
    <h2 class="titulo-seccion">Mensajes Pendientes</h2>
    <ul id="listaMensajes" class="lista-mensajes">
      <!-- Se llena con mensajes -->
    </ul>
  </section>

  <section
    id="respuestaMensaje"
    class="panel-respuesta-mensaje"
    style="display: none"
  >
    <h3 class="titulo-respuesta">Responder mensaje</h3>
    <p id="mensajeDetalle" class="detalle-mensaje"></p>
    <textarea id="respuestaText" class="textarea-respuesta"></textarea>
    <div class="contenedor-botones">
      <button id="enviarRespuesta" class="boton-enviar">Enviar</button>
      <!-- Si quieres botón cancelar agrega aquí -->
      <!-- <button id="cancelarRespuesta" class="boton-cancelar">Cancelar</button> -->
    </div>
  </section>
</div>

<script>
  async function cargarUsuarios() {
    const res = await fetch("/api/usuarios");
    const usuarios = await res.json();
    // Rellenar tablaUsuarios con datos
  }

  async function cargarMensajes() {
    const res = await fetch("/api/messages?status=pending");
    const mensajes = await res.json();
    // Rellenar listaMensajes con datos
  }

  // Añadir eventos para mostrar detalles y enviar respuestas...

  cargarUsuarios();
  cargarMensajes();
</script>
