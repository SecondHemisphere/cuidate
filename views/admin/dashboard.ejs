<div class="dashboard-contenedor" id="dashboard">
  <h1 class="titulo-dashboard">Dashboard</h1>

  <section class="tarjetas-dashboard">
    <div class="tarjeta resumen-usuarios">
      <i class="fas fa-users icono-tarjeta"></i>
      <div class="contenido-tarjeta">
        <h3>Usuarios</h3>
        <p><%= usuarios.length %></p>
        <!-- Cantidad total de usuarios -->
      </div>
    </div>

    <div class="tarjeta resumen-mensajes">
      <i class="fas fa-envelope icono-tarjeta"></i>
      <div class="contenido-tarjeta">
        <h3>Mensajes</h3>
        <p><%= mensajes.length %></p>
        <!-- Cantidad total de mensajes -->
      </div>
    </div>

    <div class="tarjeta resumen-pendientes">
      <i class="fas fa-exclamation-circle icono-tarjeta"></i>
      <div class="contenido-tarjeta">
        <h3>Pendientes</h3>
        <p><%= pendientes.length %></p>
        <!-- Cantidad de mensajes pendientes -->
      </div>
    </div>
  </section>

  <!-- Tabla con usuarios -->
  <section class="seccion-dashboard">
    <h2 class="titulo-seccion">Usuarios</h2>
    <table id="tablaUsuarios" class="tabla-usuarios">
      <tr>
        <th>ID</th>
        <th>Nombre</th>
        <th>Email</th>
      </tr>
      <% usuarios.forEach(u => { %>
      <tr>
        <td><%= u.id %></td>
        <td><%= u.nombre %></td>
        <td><%= u.email %></td>
      </tr>
      <% }) %>
    </table>
  </section>

  <!-- Lista con mensajes pendientes -->
  <section class="seccion-dashboard">
    <h2 class="titulo-seccion">Mensajes Pendientes</h2>
    <ul id="listaMensajes" class="lista-mensajes">
      <% pendientes.forEach(m => { %>
      <li><strong><%= m.nombre %></strong> - <%= m.mensaje %></li>
      <% }) %>
    </ul>
  </section>
</div>
