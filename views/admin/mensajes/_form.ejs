<form
  action="<%= formAction %>"
  method="POST"
  class="crud-form"
>
  <% if (formMethod === 'PUT') { %>
    <input type="hidden" name="_method" value="PUT" />
  <% } %>

  <div class="crud-form-grupo">
    <label for="nombre">Nombre</label>
    <input
      type="text"
      id="nombre"
      name="nombre"
      required
      class="crud-input"
      placeholder="Ingresa el nombre"
      value="<%= mensaje ? mensaje.nombre : '' %>"
    />
  </div>

  <div class="crud-form-grupo">
    <label for="email">Email</label>
    <input
      type="email"
      id="email"
      name="email"
      required
      class="crud-input"
      placeholder="Ingresa el email"
      value="<%= mensaje ? mensaje.email : '' %>"
    />
  </div>

  <div class="crud-form-grupo">
    <label for="mensaje">Mensaje</label>
    <textarea
      id="mensaje"
      name="mensaje"
      required
      class="crud-textarea"
      placeholder="Escribe el mensaje aquí"
    ><%= mensaje ? mensaje.mensaje : '' %></textarea>
  </div>

  <div class="crud-form-grupo">
    <label for="estado">Estado</label>
    <select id="estado" name="estado" required class="crud-select">
      <option value="NUEVO" <%= mensaje && mensaje.estado === 'nuevo' ? 'selected' : '' %>>Nuevo</option>
      <option value="LEIDO" <%= mensaje && mensaje.estado === 'leido' ? 'selected' : '' %>>Leído</option>
    </select>
  </div>

  <!-- Botones -->
  <div class="crud-acciones">
    <button type="submit" class="crud-btn-primario">
      <i class="fas fa-save"></i> Guardar
    </button>
    <a href="/admin/mensajes" class="crud-btn-ver">
      <i class="fas fa-arrow-left"></i> Volver
    </a>
  </div>
</form>
